//
//  Secrets.example.swift
//  Hazel
//
//  Copy this file to Secrets.swift (gitignored) and fill in real values.
//  YNAB: create an OAuth application at
//    https://app.ynab.com/settings/developer
//  Splitwise: create an OAuth application at
//    https://secure.splitwise.com/apps
//  Register OAuthConfig.ynabRedirectURI / OAuthConfig.splitwiseRedirectURI
//  as the redirect URI for each application.
//
//  Client secrets go in the hazel-oauth-relay Worker's config instead (see
//  ../oauth-relay/README.md) — only the public client IDs belong here.
//

enum Secrets {
    static let ynabClientID = "YOUR_YNAB_CLIENT_ID"
    static let splitwiseClientID = "YOUR_SPLITWISE_CLIENT_ID"
}
